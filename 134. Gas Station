class Solution {
    public int canCompleteCircuit(int[] gas, int[] cost) {

        int total = 0;   // total gas - cost
        int tank = 0;    // current fuel
        int start = 0;   // starting index

        for (int i = 0; i < gas.length; i++) {

            int diff = gas[i] - cost[i];

            total += diff;   // check overall possibility
            tank += diff;    // current journey fuel

            // if fuel becomes negative → can't start from previous start
            if (tank < 0) {
                start = i + 1; // shift start
                tank = 0;      // reset fuel
            }
        }

        // if total gas < total cost → impossible
        if (total < 0) return -1;

        return start;
    }
}
