class Solution {
    public int maxSubArray(int[] nums) {
        int max = Math.Min;
        int sum =0 ;
        for(int i = 0 ; i < nums.length ; i++)
        {
            if(sum < 0)
            {
                sum = 0;
            }
            sum = sum + nums[i];

            if(max < sum)
            {
                sum = max ;
            }
        }
        return sum;
    }
}
