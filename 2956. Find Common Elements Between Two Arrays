#include <stdlib.h>

int* findIntersectionValues(int* nums1, int nums1Size, int* nums2, int nums2Size, int* returnSize) {
    int hash1[101] = {0};
    int hash2[101] = {0};
    
    int result1 = 0;
    int result2 = 0;

    for(int i = 0; i < nums1Size; i++) {
        hash1[nums1[i]]++;
    }

    for(int i = 0; i < nums2Size; i++) {
        hash2[nums2[i]]++;
    }

    for(int i = 0; i < nums1Size; i++) {
        if(hash2[nums1[i]] > 0) {
            result1++;
        }
    }

    for(int i = 0; i < nums2Size; i++) {
        if(hash1[nums2[i]] > 0) {
            result2++;
        }
    }

    int* result = (int*)malloc(2 * sizeof(int));
    result[0] = result1;
    result[1] = result2;

    *returnSize = 2;

    return result;
}
