class Solution {
    public int jump(int[] nums) {

        int jumps = 0;
        int currentEnd = 0;
        int farthest = 0;

        for (int i = 0; i < nums.length - 1; i++) {

            // find farthest we can reach
            farthest = Math.max(farthest, i + nums[i]);

            // if we reached end of current range
            if (i == currentEnd) {
                jumps++;               // take jump
                currentEnd = farthest; // move to next range
            }
        }

        return jumps;
    }
}
